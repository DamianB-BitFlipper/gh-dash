{
  "name": "pipediffshub",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "pipediffshub": "./pipediffshub"
  },
  "scripts": {
    "build": "vite build",
    "build:cli": "bun ./scripts/embed-dist.ts && bun build --compile ./bin/pipediffshub.ts --outfile ./pipediffshub",
    "build:all": "bun run build && bun run build:cli",
    "dev": "vite --host 127.0.0.1",
    "pipediffshub": "bun ./bin/pipediffshub.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pierre/diffs": "1.2.2",
    "@pierre/icons": "0.5.0",
    "@pierre/theme": "1.0.3",
    "@pierre/trees": "1.0.0-beta.4",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-slot": "1.2.3",
    "@radix-ui/react-switch": "1.2.6",
    "@tailwindcss/vite": "4.1.13",
    "@vitejs/plugin-react": "5.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.545.0",
    "vite": "7.1.12",
    "tailwind-merge": "3.3.1",
    "tailwindcss": "4.1.13",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}
